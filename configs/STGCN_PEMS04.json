{
    "SEED": 42,
    "DEVICE": "cuda:1",
    "NUM_WORKERS": 2,

    "DATASET_NAME": "PEMS04",
    "DATA_FILE_PATH": "STGCN_data/PEMS04/PEMS04.npz",
    "ADJ_FILE_PATH": "STGCN_data/PEMS04/adj_PEMS04.pkl",

    "INPUT_LENGTH": 12,
    "OUTPUT_LENGTH": 12,
    "NUM_NODES": 307,
    "NUM_FEATURES": 3,

    "MODEL_NAME": "STGCN",
    "MODEL_ARGS": {
        "Kt": 3,
        "Ks": 3,
        "blocks": [[1, 32, 64], [64, 64, 128], [128, 128, 256]],
        "dropout": 0.1,
        "graph_conv_type": "cheb_conv"
    },

    "TRAIN_NUM_EPOCHS": 100,
    "TRAIN_BATCH_SIZE": 32,
    "TRAIN_LEARNING_RATE": 0.001,
    "TRAIN_WEIGHT_DECAY": 0.0001,
    "TRAIN_EARLY_STOPPING_PATIENCE": 20,

    "VAL_BATCH_SIZE": 32,
    "TEST_BATCH_SIZE": 32,

    "LOSS_FUNCTION": "masked_mae",
    "METRICS": ["MAE", "RMSE", "MAPE"],

    "LOG_DIR": "outputs/STGCN_PEMS04",
    "SAVE_MODEL": true,
    "PRINT_FREQ": 10,

    "MAX_TRAIN_SAMPLES": 100,
    "MAX_VAL_SAMPLES": 100,
    "MAX_TEST_SAMPLES": 100
}